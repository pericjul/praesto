# Vorlage für /opt/praesto/.env auf der Exoscale-VM.
# Kopieren zu ".env", echte Werte eintragen. NIEMALS committen!

# --- Datenbank (Exoscale Managed PostgreSQL, Zürich) ---
DB_URL=jdbc:postgresql://<host>.db.exo.io:21699/defaultdb?sslmode=require
DB_USERNAME=avnadmin
DB_PASSWORD=changeme

# --- Auth ---
JWT_SECRET=mindestens-32-zeichen-langer-zufallsstring
SUPER_ADMIN_EMAIL=admin@praesto.ch
SUPER_ADMIN_PASSWORD=changeme

# --- KI: Azure OpenAI (Switzerland North) – Daten bleiben in der CH ---
# Leer lassen = KI-Funktionen nutzen Fallbacks (kein echter KI-Aufruf).
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://<dein-openai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# --- Optional ---
NODE_ENV=production
